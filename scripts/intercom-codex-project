#!/usr/bin/env bash
set -u

# Supported project supervisor for one dedicated Codex app-server and one Intercom
# adapter/proxy. Configure binary locations with CODEX_BIN and INTERCOM_BIN.
# Runtime arguments other than help and the launcher-owned transport and session
# selection options are forwarded to `intercom codex`.

codex_bin=${CODEX_BIN:-codex}
intercom_bin=${INTERCOM_BIN:-intercom}
startup_timeout=${INTERCOM_CODEX_STARTUP_TIMEOUT_SECONDS:-30}
shutdown_timeout=${INTERCOM_CODEX_SHUTDOWN_TIMEOUT_SECONDS:-40}

usage() {
  printf '%s\n' \
    'Usage:' \
    '  intercom-codex-project [--name NAME] [--cwd DIRECTORY] [--new]' \
    '  intercom-codex-project [--name NAME] [--cwd DIRECTORY] --adopt [SESSION_ID]' \
    '  intercom-codex-project [--name NAME] [--cwd DIRECTORY] --fork-from [SESSION_ID]' \
    '  intercom-codex-project [--cwd DIRECTORY] --list-sessions [--all-sessions]' \
    '' \
    'Description:' \
    '  Starts one dedicated Codex app-server and one Intercom Codex adapter/proxy.' \
    '  After readiness, the adapter prints commands for attaching a Codex TUI.' \
    '  The service group runs in the foreground until either child exits or a' \
    '  terminating signal arrives. Polling checks the adapter before app-server.' \
    '' \
    'Options:' \
    '  --name NAME       Sets the Intercom peer name.' \
    '  --cwd DIRECTORY   Sets the managed project directory.' \
    '  --new             Starts a new managed thread and replaces its binding.' \
    '  --adopt [ID]      Adopts an interactive session. Omitting ID opens a picker.' \
    '  --fork-from [ID]  Forks an interactive session. Omitting ID opens a picker.' \
    '  --all-sessions    Includes sessions from every working directory in selection.' \
    '  --list-sessions   Lists resumable sessions and exits.' \
    '  --replace-binding Replaces an existing peer binding during adopt or fork.' \
    '  --yolo            Disables approvals and the Codex sandbox for managed turns.' \
    '  --dangerously-bypass-approvals-and-sandbox' \
    '                    Alias for --yolo.' \
    '  -h, --help        Prints this help text and exits.' \
    '' \
    'Environment:' \
    '  CODEX_BIN                                  Codex executable; default: codex.' \
    '  INTERCOM_BIN                               Source default: intercom; package: bundled.' \
    '  INTERCOM_CODEX_STARTUP_TIMEOUT_SECONDS      Readiness timeout; empty/default: 30.' \
    '  INTERCOM_CODEX_SHUTDOWN_TIMEOUT_SECONDS     Per-child timeout; empty/default: 40.' \
    '  XDG_RUNTIME_DIR                            Temporary socket directory base.' \
    '  TMPDIR                                     Fallback socket directory base.' \
    '' \
    'Exit status:' \
    '  0     Help was requested or the adapter exited successfully.' \
    '  1     Launcher failure, app-server status 0, or observed child status 1.' \
    '  2     Launcher validation failure or observed child status 2.' \
    '  129   SIGHUP terminated the launcher, or an observed child returned 129.' \
    '  130   SIGINT terminated the launcher, or an observed child returned 130.' \
    '  143   SIGTERM terminated the launcher, or an observed child returned 143.' \
    '  Other The nonzero status of the child observed to have exited.'
}

show_help=0
for arg in "$@"; do
  case $arg in
    -h | --help)
      show_help=1
      ;;
    --app-server | --app-server=* | --client-endpoint | --client-endpoint=* | --mcp-bridge | --mcp-bridge=*)
      option=${arg%%=*}
      printf 'intercom-codex-project: %s is managed by the launcher and must not be supplied\n' "$option" >&2
      exit 2
      ;;
    --adopt-session | --adopt-session=* | --fork-session | --fork-session=*)
      option=${arg%%=*}
      printf 'intercom-codex-project: %s is internal; use --adopt or --fork-from\n' "$option" >&2
      exit 2
      ;;
  esac
done
if ((show_help)); then
  usage
  exit 0
fi

forwarded_args=()
adapter_only_args=()
selection_mode=
selection_id=
selection_needs_picker=0
all_sessions=0
list_sessions=0
fresh=0
replace_binding=0
selector_cwd=

selection_conflict() {
  printf 'intercom-codex-project: --new, --adopt, --fork-from, and --list-sessions are mutually exclusive\n' >&2
  exit 2
}

set_selection() {
  local mode=$1
  local id=$2
  local needs_picker=$3
  if [[ -n $selection_mode ]] || ((fresh)) || ((list_sessions)); then
    selection_conflict
  fi
  selection_mode=$mode
  selection_id=$id
  selection_needs_picker=$needs_picker
}

while (($#)); do
  arg=$1
  shift
  case $arg in
    --adopt | --fork-from)
      mode=adopt
      [[ $arg == --fork-from ]] && mode=fork
      id=
      needs_picker=1
      if (($#)) && [[ $1 != -* ]]; then
        id=$1
        shift
        needs_picker=0
      fi
      set_selection "$mode" "$id" "$needs_picker"
      ;;
    --adopt=* | --fork-from=*)
      mode=adopt
      [[ $arg == --fork-from=* ]] && mode=fork
      id=${arg#*=}
      if [[ -z $id ]]; then
        printf 'intercom-codex-project: %s requires a nonempty session id after =\n' "${arg%%=*}" >&2
        exit 2
      fi
      set_selection "$mode" "$id" 0
      ;;
    --all-sessions)
      all_sessions=1
      ;;
    --list-sessions)
      if [[ -n $selection_mode ]] || ((fresh)) || ((list_sessions)); then
        selection_conflict
      fi
      list_sessions=1
      ;;
    --new)
      if [[ -n $selection_mode ]] || ((list_sessions)) || ((fresh)); then
        selection_conflict
      fi
      fresh=1
      forwarded_args+=("$arg")
      ;;
    --replace-binding)
      replace_binding=1
      forwarded_args+=("$arg")
      ;;
    --cwd)
      if (($# == 0)); then
        printf 'intercom-codex-project: --cwd requires a directory\n' >&2
        exit 2
      fi
      selector_cwd=$1
      forwarded_args+=("$arg" "$1")
      shift
      ;;
    --cwd=*)
      selector_cwd=${arg#*=}
      forwarded_args+=("$arg")
      ;;
    *)
      forwarded_args+=("$arg")
      adapter_only_args+=("$arg")
      ;;
  esac
done

if ((all_sessions)) && ((!list_sessions && !selection_needs_picker)); then
  printf 'intercom-codex-project: --all-sessions requires --list-sessions or an ID-less --adopt/--fork-from\n' >&2
  exit 2
fi
if ((replace_binding)) && [[ -z $selection_mode ]]; then
  printf 'intercom-codex-project: --replace-binding requires --adopt or --fork-from\n' >&2
  exit 2
fi
if ((list_sessions)) && ((${#adapter_only_args[@]} != 0)); then
  printf 'intercom-codex-project: --list-sessions does not accept adapter argument %s\n' "${adapter_only_args[0]}" >&2
  exit 2
fi

# Timeout values are multiplied by ten for decisecond polling. Keep the
# canonical value within signed 64-bit arithmetic even after that multiply.
max_timeout_seconds=922337203685477580

parse_timeout() {
  local name=$1
  local value=$2
  local output=$3

  case $value in
    '' | *[!0-9]*)
      printf 'intercom-codex-project: %s must be a positive integer\n' "$name" >&2
      exit 2
      ;;
  esac
  local leading_zeros=${value%%[!0]*}
  value=${value#"$leading_zeros"}
  if [[ -z $value ]] || ((${#value} > ${#max_timeout_seconds})) ||
    ((${#value} == ${#max_timeout_seconds} && 10#$value > max_timeout_seconds)); then
    printf 'intercom-codex-project: %s must be a positive integer no greater than %s\n' \
      "$name" "$max_timeout_seconds" >&2
    exit 2
  fi
  printf -v "$output" '%d' "$((10#$value))"
}

parse_timeout INTERCOM_CODEX_STARTUP_TIMEOUT_SECONDS "$startup_timeout" startup_timeout
parse_timeout INTERCOM_CODEX_SHUTDOWN_TIMEOUT_SECONDS "$shutdown_timeout" shutdown_timeout

runtime_base=${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}
runtime_dir=$(mktemp -d "${runtime_base%/}/intercom-codex.XXXXXX") || exit 1
if ! chmod 700 "$runtime_dir"; then
  rm -rf "$runtime_dir"
  exit 1
fi
if ! canonical_runtime_dir=$(cd "$runtime_dir" && pwd -P); then
  rm -rf "$runtime_dir"
  exit 1
fi
runtime_dir=$canonical_runtime_dir
case $runtime_dir in
  *['%?#']*)
    printf 'intercom-codex-project: runtime directory contains URL-delimiter byte: %s\n' "$runtime_dir" >&2
    rm -rf "$runtime_dir"
    exit 2
    ;;
esac
app_server_socket_path=$runtime_dir/app-server.sock
client_socket_path=$runtime_dir/client.sock
mcp_bridge_socket_path=$runtime_dir/mcp-bridge.sock
app_server_endpoint=unix://$app_server_socket_path
client_endpoint=unix://$client_socket_path

server_pid=
adapter_pid=
cleaned=0

is_running() {
  local want=$1
  local pid
  while IFS= read -r pid; do
    if [[ $pid == "$want" ]]; then
      return 0
    fi
  done < <(jobs -pr)
  return 1
}

wait_dead() {
  local pid=$1
  local timeout=$2
  local ticks=$((timeout * 10))
  local i
  for ((i = 0; i < ticks; i++)); do
    if ! is_running "$pid"; then
      return 0
    fi
    sleep 0.1
  done
  return 1
}

stop_process() {
  local pid=$1
  local label=$2
  if [[ -z $pid ]] || ! is_running "$pid"; then
    if [[ -n $pid ]]; then
      wait "$pid" 2>/dev/null || true
    fi
    return
  fi
  kill -TERM "$pid" 2>/dev/null || true
  if ! wait_dead "$pid" "$shutdown_timeout"; then
    printf 'intercom-codex-project: %s did not stop; killing it\n' "$label" >&2
    kill -KILL "$pid" 2>/dev/null || true
  fi
  wait "$pid" 2>/dev/null || true
}

cleanup() {
  if ((cleaned)); then
    return
  fi
  cleaned=1
  # The adapter must disappear from the broker and drain its turn before the
  # app-server is stopped.
  stop_process "$adapter_pid" adapter
  stop_process "$server_pid" app-server
  rm -rf "$runtime_dir"
}

on_signal() {
  local status=$1
  trap - INT TERM HUP EXIT
  cleanup
  exit "$status"
}

trap 'on_signal 130' INT
trap 'on_signal 143' TERM
trap 'on_signal 129' HUP
trap cleanup EXIT

# App-server diagnostics belong on the launcher's diagnostic stream. The
# adapter/proxy retains stdout for its post-readiness attachment instructions.
"$codex_bin" app-server --listen "$app_server_endpoint" 1>&2 &
server_pid=$!

# Waiting for the socket avoids a noisy initial failure while the adapter's
# own bounded dial retry verifies the actual WebSocket handshake.
startup_ticks=$((startup_timeout * 10))
for ((i = 0; i < startup_ticks; i++)); do
  if [[ -S $app_server_socket_path ]]; then
    break
  fi
  if ! is_running "$server_pid"; then
    wait "$server_pid" || status=$?
    printf 'intercom-codex-project: app-server exited before readiness\n' >&2
    exit "${status:-1}"
  fi
  sleep 0.1
done
if [[ ! -S $app_server_socket_path ]]; then
  printf 'intercom-codex-project: app-server was not ready after %ss\n' "$startup_timeout" >&2
  exit 1
fi

if ((list_sessions)) || ((selection_needs_picker)); then
  session_args=(codex sessions --app-server "$app_server_endpoint")
  if [[ -n $selector_cwd ]]; then
    session_args+=(--cwd "$selector_cwd")
  fi
  if ((all_sessions)); then
    session_args+=(--all)
  fi
  if ((list_sessions)); then
    session_args+=(--list)
    "$intercom_bin" "${session_args[@]}"
    status=$?
    exit "$status"
  fi

  selection_id=$("$intercom_bin" "${session_args[@]}")
  status=$?
  if ((status != 0)); then
    exit "$status"
  fi
  if [[ -z $selection_id ]] || [[ $selection_id == *$'\n'* ]]; then
    printf 'intercom-codex-project: session selector returned an invalid session id\n' >&2
    exit 1
  fi
fi

selection_args=()
case $selection_mode in
  adopt)
    selection_args=(--adopt-session "$selection_id")
    ;;
  fork)
    selection_args=(--fork-session "$selection_id")
    ;;
esac

"$intercom_bin" codex \
  --app-server "$app_server_endpoint" \
  --client-endpoint "$client_endpoint" \
  --mcp-bridge "$mcp_bridge_socket_path" \
  "${selection_args[@]}" \
  "${forwarded_args[@]}" &
adapter_pid=$!

while :; do
  if ! is_running "$adapter_pid"; then
    status=0
    wait "$adapter_pid" || status=$?
    adapter_pid=
    stop_process "$server_pid" app-server
    server_pid=
    exit "$status"
  fi
  if ! is_running "$server_pid"; then
    status=0
    wait "$server_pid" || status=$?
    server_pid=
    stop_process "$adapter_pid" adapter
    adapter_pid=
    if ((status == 0)); then
      status=1
    fi
    exit "$status"
  fi
  sleep 0.1
done
